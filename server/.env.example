PORT=3001

# Local Docker defaults — see ../docker-compose.yml (mysql service / MYSQL_* vars)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=beacon
MYSQL_PASSWORD=beacon_local_pass
MYSQL_DATABASE=beaconnh

# Your own MySQL / PlanetScale / RDS — replace MYSQL_* above.

CORS_ORIGIN=http://localhost:5173

# Firebase Admin — SAME project as VITE_FIREBASE_* on the web app.
# Put the downloaded JSON in this folder (any name). Point GOOGLE_APPLICATION_CREDENTIALS at it:
#   ./firebase-admin.json  OR  ./your-project-firebase-adminsdk-xxxx.json
# See firebase-admin.example.json for the JSON shape only (do not commit real keys).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-admin.json
