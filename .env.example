# Local frontend (Vite). In production, set these on **Vercel** (build time), not on Railway’s API.
# See DEPLOYMENT.md → “Where each variable goes”.
#
# Firebase (optional — without these, events & RSVPs use local browser storage)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API (MySQL). When set, events & RSVPs use this API; Firebase Auth still used for /admin.
# Host API (npm run api:dev): http://localhost:3001
# Docker API (npm run docker:stack): http://localhost:3002
VITE_API_URL=http://localhost:3001

# WhatsApp chat link (digits only, country code included, e.g. 16035551234)
VITE_WHATSAPP_E164=

# Local-only admin when Firebase is not configured (omit in production if using Firebase)
VITE_LOCAL_ADMIN_PASSWORD=

# Admin UI: omitted or false in production = /admin is not built into the app (local dev always has admin).
# Set to true only on trusted deploys where staff need the dashboard.
# VITE_PUBLIC_ADMIN=true
# Optional: obscure URL (single segment, no slashes). Example: VITE_ADMIN_ROUTE=ops-7f3a9c2e
# VITE_ADMIN_ROUTE=admin

# Footer mailto (optional)
VITE_CONTACT_EMAIL=

# Optional: urgent site-wide banner (plain text). Pair with UNTIL so it auto-hides after that local date.
# VITE_POLICY_ALERT=Important: example policy change — confirm with your case manager or 211 NH.
# VITE_POLICY_ALERT_UNTIL=2026-12-31

# Optional: floating AI guide (calls VITE_API_URL + POST /api/ai-assistant on your Beacon API)
# VITE_AI_HELPER_ENABLED=true

# Optional: npm run smoke:api (defaults to http://localhost:3001 if unset)
# SMOKE_API_URL=https://your-api.up.railway.app
